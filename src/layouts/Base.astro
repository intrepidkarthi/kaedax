---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { SITE_URL, EMAIL, HQ } from "../data/site";
import { socials } from "../data/socials";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Extra JSON-LD blocks (Service, FAQPage, BreadcrumbList, Article …) */
  jsonLd?: Record<string, unknown>[];
}

const {
  title = "kaedax — Agent-first software, shipped in 720 hours",
  description = "kaedax is an AI-native software agency. Fixed-fee, agent-driven software builds delivered in 30 days. For bootstrapped founders who can't wait six months.",
  ogImage = "/og-default.png",
  noindex = false,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).toString();

/* Sitewide entity schema — Organization + WebSite. Entity consistency is an
   AEO signal: same name, address, and sameAs links everywhere. */
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE_URL}/#org`,
  name: "kaedax",
  url: SITE_URL,
  email: EMAIL,
  description:
    "AI-native software studio. Agent-first software delivery on a fixed 30-day (720-hour) cycle for founders in fintech, healthtech, insurance, ecommerce, and AI products.",
  address: {
    "@type": "PostalAddress",
    streetAddress: HQ.area,
    addressLocality: HQ.city,
    addressRegion: HQ.region,
    postalCode: HQ.postalCode,
    addressCountry: HQ.country,
  },
  areaServed: "Worldwide",
  knowsAbout: [
    "agent-first software development", "fintech software development",
    "HIPAA-compliant software development", "AI agent development",
    "insurance software development", "ecommerce development",
    "marketplace development", "internal tools development",
  ],
  sameAs: socials.filter((s) => s.external).map((s) => s.href),
};

const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  url: SITE_URL,
  name: "kaedax",
  publisher: { "@id": `${SITE_URL}/#org` },
};

const ldBlocks = [orgLd, siteLd, ...jsonLd];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="kaedax — agent-first software, shipped in 720 hours" />
    <meta property="og:site_name" content="kaedax" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#07090a" />

    {ldBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="font-sans text-bone-50 antialiased">
    <div class="grain" aria-hidden="true"></div>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
