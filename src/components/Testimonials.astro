---
import { testimonials } from "../data/testimonials";

const featured = testimonials.slice(0, 3);
---
<section id="testimonials" class="relative py-24 md:py-32 border-t border-[color:var(--color-ink-800)]">
  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[color:var(--color-volt-400)] mb-6">
          <span class="text-[color:var(--color-bone-500)]">[ §04.5 ]</span> in their words
        </p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl leading-[0.92] tracking-[-0.035em]">
          What founders say<br/>
          <span class="editorial-italic text-[color:var(--color-bone-400)]">after the cycle.</span>
        </h2>
      </div>
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-bone-500)] md:pb-2">
        founders &amp; operators · roles as delivered
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-[color:var(--color-ink-800)] border border-[color:var(--color-ink-800)]">
      {featured.map((t) => (
        <blockquote class="bg-[color:var(--color-ink-950)] p-8 md:p-9 flex flex-col">
          <span class="font-serif italic text-4xl text-[color:var(--color-volt-400)] leading-none mb-5" aria-hidden="true">“</span>
          <p class="text-[color:var(--color-bone-200)] leading-[1.65] text-[15px] md:text-base flex-1">
            {t.quote}
          </p>
          <footer class="mt-7 pt-5 border-t border-dashed border-[color:var(--color-ink-700)] flex items-center gap-4">
            <img
              src={t.avatar}
              alt={t.name}
              width="44"
              height="44"
              loading="lazy"
              class="w-11 h-11 object-cover border border-[color:var(--color-ink-600)] grayscale contrast-110 saturate-[0.85]"
            />
            <div class="min-w-0">
              <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-bone-50)]">{t.name}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.16em] text-[color:var(--color-bone-400)] leading-relaxed">
                {t.role}
              </p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
