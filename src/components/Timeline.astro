---
const phases = [
  {
    range: "Day 01 — 03",
    hours: "T+000 → T+072",
    title: "Brief → spec",
    body: "You talk to a human. We talk to scope.agent. By day 3 there's a signed spec, an ADR log, and a Figma flow — not a 40-slide proposal.",
    artifacts: ["spec.md", "adr/", "ux/flows.fig"],
  },
  {
    range: "Day 04 — 21",
    hours: "T+073 → T+504",
    title: "Agent-driven build",
    body: "Build, QA, deploy agents run on a tight loop. Two human engineers steer, review every PR, and own the hard judgement calls. You watch the cycle log in real time.",
    artifacts: ["main · 87 PRs", "vitest · 91% cov", "preview deploys × 14"],
  },
  {
    range: "Day 22 — 27",
    hours: "T+505 → T+648",
    title: "Polish + integration",
    body: "The unglamorous week. Edge cases, error states, onboarding copy, perf budgets, the analytics you forgot to ask for. This is the part shops skip.",
    artifacts: ["lighthouse 99+", "sentry armed", "stripe live"],
  },
  {
    range: "Day 28 — 30",
    hours: "T+649 → T+720",
    title: "Handoff + ship",
    body: "Production cutover. You get the repo, the agents, the runbooks, the dashboards. We're on call for 30 days after — no extra invoice.",
    artifacts: ["prod live", "runbook.md", "30d on-call"],
  },
];
---
<section id="how" class="relative py-24 md:py-36 border-t border-[color:var(--color-ink-800)]">
  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 mb-16 md:mb-24">
      <div class="lg:sticky lg:top-24 self-start">
        <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[color:var(--color-volt-400)] mb-6">
          <span class="text-[color:var(--color-bone-500)]">[ §02 ]</span> the 720h cycle
        </p>
        <h2 class="font-display text-4xl md:text-6xl leading-[0.92] tracking-[-0.035em]">
          What thirty days<br/>
          <span class="editorial-italic text-[color:var(--color-bone-400)]">actually looks like.</span>
        </h2>
        <p class="mt-6 text-base text-[color:var(--color-bone-200)] max-w-[42ch] leading-relaxed">
          No mystery, no Gantt theatre. Four phases, four artifacts, one fixed deadline.
        </p>
      </div>

      <ol class="relative">
        <span class="absolute left-[7px] top-2 bottom-2 w-px bg-[color:var(--color-ink-800)]" aria-hidden="true"></span>
        {phases.map((p, i) => (
          <li class="relative pl-10 pb-14 last:pb-0">
            <span class="absolute left-0 top-1.5 w-4 h-4 border border-[color:var(--color-volt-400)] bg-[color:var(--color-ink-950)] flex items-center justify-center">
              <span class="w-1.5 h-1.5 bg-[color:var(--color-volt-400)]"></span>
            </span>
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-2">
              <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[color:var(--color-volt-400)]">
                {p.range}
              </p>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-bone-500)]">
                {p.hours}
              </p>
            </div>
            <h3 class="font-display text-2xl md:text-3xl tracking-[-0.025em] mb-3">
              {p.title}
            </h3>
            <p class="text-[color:var(--color-bone-200)] leading-[1.65] max-w-[58ch]">{p.body}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.artifacts.map((a) => (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-[color:var(--color-ink-700)] bg-[color:var(--color-ink-900)] font-mono text-[10px] uppercase tracking-[0.16em] text-[color:var(--color-bone-200)]">
                  <span class="text-[color:var(--color-volt-400)]">↳</span>{a}
                </span>
              ))}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
