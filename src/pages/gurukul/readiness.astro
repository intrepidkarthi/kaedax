---
/**
 * /gurukul/readiness — the school AI-readiness check.
 *
 * Forwardable lead magnet for principals & school directors: 8 questions,
 * 2 minutes, no email gate. Result links to the Gurukul demo and a
 * walkthrough call. Same standalone light theme as /gurukul.
 */
import "../../styles/global.css";
import ReadinessScorer from "../../components/gurukul/ReadinessScorer.tsx";
import { SITE_URL } from "../../data/site";

const title = "Is your school AI-ready? Free 2-minute check · Gurukul by kaedax";
const description =
  "8 questions, 2 minutes, no sign-up: score your school's AI readiness across policy, teachers, curriculum (CBSE AI 417/843, NEP 2020), infrastructure, parents, and DPDP data protection — with your three highest-leverage next steps.";

const quizLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "School AI-Readiness Check",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Web",
  description,
  url: `${SITE_URL}/gurukul/readiness`,
  offers: { "@type": "Offer", price: "0", priceCurrency: "INR" },
  creator: { "@id": `${SITE_URL}/#org` },
};
---
<!doctype html>
<html lang="en" style="color-scheme: light;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${SITE_URL}/gurukul/readiness`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1b2026" />
    <script type="application/ld+json" set:html={JSON.stringify(quizLd)} />
    <style>
      html, body { background: #f3eee3 !important; }
      ::-webkit-scrollbar-track { background: #f3eee3 !important; }
      ::-webkit-scrollbar-thumb { background: #c9c2b2 !important; }
      ::selection { background: #e8650a !important; color: #fff !important; }
      @media print {
        .print\:hidden { display: none !important; }
      }
    </style>
  </head>
  <body class="antialiased">
    <!-- kaedax attribution bar -->
    <div class="flex items-center justify-between gap-3 bg-[#07090a] px-4 sm:px-6 py-2 print:hidden">
      <a href="/edtech-software-development" class="font-mono text-[10px] uppercase tracking-[0.18em] text-[#8b8e88] hover:text-[#c1ff3a] transition-colors">
        ← kaedax
      </a>
      <a href="/gurukul" class="font-mono text-[10px] uppercase tracking-[0.18em] text-[#8b8e88] hover:text-[#c1ff3a] transition-colors text-center">
        <span class="text-[#c1ff3a]">●</span> try the Gurukul live demo →
      </a>
    </div>

    <main class="max-w-[720px] mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <header class="mb-8">
        <p class="font-display text-xl font-bold tracking-[-0.02em] text-[#15191e] mb-6">
          गुरु<span class="text-[#e8650a]">kul</span>
          <span class="font-mono text-[9px] uppercase tracking-[0.22em] text-[#9b9588] font-normal ml-2">the AI classroom</span>
        </p>
        <h1 class="font-display text-3xl sm:text-[2.6rem] font-semibold tracking-[-0.025em] leading-[1.05] text-[#15191e]">
          Is your school <span class="text-[#e8650a]">AI-ready?</span>
        </h1>
        <p class="mt-4 text-[15.5px] leading-[1.7] text-[#3a4048] max-w-[58ch]">
          Your students already use AI. NEP 2020 expects coding and AI exposure from Class 6, and
          CBSE offers AI as a skill subject (codes 417 &amp; 843). Eight questions, two minutes,
          no sign-up — get your score and your three highest-leverage next steps.
        </p>
      </header>

      <ReadinessScorer client:only="react" />

      <footer class="mt-12 pt-6 border-t-2 border-[#1b2026]/10 print:hidden">
        <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-[#9b9588] leading-relaxed">
          Built by <a href="/" class="text-[#e8650a] hover:underline">kaedax</a> — agent-first software, shipped in 720 hours.
          Forward this check to a principal who needs it.
        </p>
      </footer>
    </main>

    <noscript>
      <div style="padding: 4rem 2rem; text-align: center; font-family: monospace;">
        The readiness check is interactive — please enable JavaScript.
      </div>
    </noscript>
  </body>
</html>
