---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base
  title="Field notes — kaedax"
  description="Essays from kaedax on agent-first development, the 720-hour delivery loop, and the engineering economy after agents."
>
  <section class="relative pt-32 pb-20 md:pt-40">
    <div class="absolute inset-0 hairline-grid opacity-30"></div>
    <div class="relative max-w-[1100px] mx-auto px-6 lg:px-10">
      <div class="border-b border-[color:var(--color-ink-800)] pb-12 mb-12">
        <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[color:var(--color-volt-400)] mb-6">
          /field-notes
        </p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[0.9] tracking-[-0.04em]">
          Field notes<br/>
          <span class="editorial-italic text-[color:var(--color-bone-400)]">from the cycle.</span>
        </h1>
        <p class="mt-6 text-lg text-[color:var(--color-bone-200)] max-w-[58ch] leading-relaxed">
          Essays on agent-first development, the 720-hour loop, and the slow rebuild of the
          software-services economy. Mostly written between cycles, never ghostwritten.
        </p>
      </div>

      <ol class="divide-y divide-[color:var(--color-ink-800)]">
        {posts.map((p, i) => (
          <li>
            <a href={`/blog/${p.id}`} class="group block py-8 md:py-10">
              <div class="grid md:grid-cols-[80px_140px_1fr_120px] gap-4 md:gap-8 items-baseline">
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-bone-500)]">
                  {String(posts.length - i).padStart(2, "0")}
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-volt-400)]">
                  {p.data.tag}
                </span>
                <div>
                  <h2 class="font-display text-2xl md:text-3xl tracking-[-0.025em] leading-tight group-hover:text-[color:var(--color-volt-400)] transition-colors">
                    {p.data.title}
                  </h2>
                  <p class="mt-2 text-[color:var(--color-bone-200)] leading-[1.55] max-w-[64ch]">
                    {p.data.description}
                  </p>
                </div>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-bone-500)] md:text-right">
                  {p.data.date.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Base>
